@page "/pages/TrdBx/Invoices"

@using CleanArchitecture.Blazor.Application.Features.Invoices.Caching
@using CleanArchitecture.Blazor.Application.Features.Invoices.Commands.Create
@using CleanArchitecture.Blazor.Application.Features.Invoices.Commands.Delete
@using CleanArchitecture.Blazor.Application.Features.Invoices.Commands.SetAsCanceled
@using CleanArchitecture.Blazor.Application.Features.Invoices.Commands.SetAsPaid
@using CleanArchitecture.Blazor.Application.Features.Invoices.Commands.SetNextStatus
@using CleanArchitecture.Blazor.Application.Features.Invoices.Commands.SetPreviousStatus
@using CleanArchitecture.Blazor.Application.Features.Invoices.Commands.Update
@using CleanArchitecture.Blazor.Application.Features.Invoices.DTOs
@using CleanArchitecture.Blazor.Application.Features.Invoices.Queries.Download
@using CleanArchitecture.Blazor.Application.Features.Invoices.Queries.Export
@using CleanArchitecture.Blazor.Application.Features.Invoices.Queries.Pagination
@using CleanArchitecture.Blazor.Application.Features.Invoices.Specifications
@using CleanArchitecture.Blazor.Domain.Enums
@using CleanArchitecture.Blazor.Server.UI.Pages.TrdBx.Invoices.Components

@inject IStringLocalizer<Invoices> L
@attribute [Authorize(Policy = Permissions.Invoices.View)]
@inject BlazorDownloadFileService BlazorDownloadFileService

<PageTitle>@Title</PageTitle>

<AdvancedSearchInvoices TRequest="Query" OnConditionChanged="ConditionChanged"></AdvancedSearchInvoices>
<style>
    .mud-table-toolbar {
        height: 120px !important;
    }
</style>

<MudDataGrid ServerData="@(ServerReload)"
             FixedHeader="true"
             FixedFooter="false"
             Virtualize="false"
             @bind-RowsPerPage="_defaultPageSize"
             Loading="@_loading"
             MultiSelection="true"
             T="InvoiceDto"
             SelectOnRowClick="false"
             RowClick="@(s=>OnView(s.Item))"
             @bind-SelectedItems="_selectedItems"
             Hover="true" @ref="_table">

    <ToolBarContent>
        <MudStack Row Spacing="0" Class="flex-grow-1" Justify="Justify.SpaceBetween">
            <MudStack Row AlignItems="AlignItems.Start">
                <MudIcon Icon="@Icons.Material.Filled.Window" Size="Size.Large" />
                <MudStack Spacing="0">
                    <MudText Typo="Typo.subtitle2" Class="mb-2">@Title</MudText>
                    <MudEnumSelect Style="min-width:120px" TEnum="InvoiceListView" ValueChanged="OnChangedListView" Value="Query.ListView" Dense="true" Label="@L["List View"]">
                    </MudEnumSelect>
                </MudStack>
            </MudStack>
            <MudStack Spacing="0" AlignItems="AlignItems.End">
                <MudToolBar Dense WrapContent="true" Class="py-1 px-0">
                    <MudButton Disabled="@_loading"
                               OnClick="@(() => OnRefresh())"
                               StartIcon="@Icons.Material.Outlined.Refresh">
                        @AppStrings.Refresh
                    </MudButton>
                    @if (_accessRights.Create)
                    {
                        <MudButton StartIcon="@Icons.Material.Outlined.Add"
                        OnClick="OnCreate">
                            @AppStrings.New
                        </MudButton>
                    }
                    <MudMenu TransformOrigin="Origin.BottomRight" AnchorOrigin="Origin.BottomRight" EndIcon="@Icons.Material.Filled.MoreVert" Label="@AppStrings.More">
                        @if (_accessRights.Export)
                        {
                            <MudMenuItem Disabled="@_exporting"
                            OnClick="OnExport">
                                @AppStrings.Export
                            </MudMenuItem>
                        }
                    </MudMenu>
                </MudToolBar>
                <MudStack Row Spacing="1">
                    @if (_accessRights.Search)
                    {
                        <MudTextField T="string" ValueChanged="@(s => OnSearch(s))" Value="@Query.Keyword" Placeholder="@AppStrings.Search" Adornment="Adornment.End"
                        AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Small">
                        </MudTextField>
                    }
                </MudStack>
            </MudStack>
        </MudStack>
    </ToolBarContent>
    <Columns>
        <SelectColumn ShowInFooter="false"></SelectColumn>
        <TemplateColumn HeaderStyle="width:60px" Title="@AppStrings.Actions" Sortable="false">
            <CellTemplate>
                @if (_accessRights.Edit || _accessRights.Delete)
                {
                    <MudMenu Icon="@Icons.Material.Filled.Edit" Variant="Variant.Filled" Size="Size.Small"
                    Dense="true"
                    EndIcon="@Icons.Material.Filled.KeyboardArrowDown" IconColor="Color.Info" AnchorOrigin="Origin.CenterLeft">

                        @if (_accessRights.Export)
                        {
                            <MudMenuItem OnClick="@(()=>OnSetNextStatus(context.Item))">Next Status</MudMenuItem>
                        }
                        @if (_accessRights.Export)
                        {
                            <MudMenuItem OnClick="@(()=>OnSetPreviousStatus(context.Item))">Previous Status</MudMenuItem>
                        }
                        @if (_accessRights.Export)
                        {
                            <MudMenuItem OnClick="@(()=>OnDownLoad(context.Item))">@AppStrings.Download</MudMenuItem>
                        }
                        @if (_accessRights.Edit)
                        {
                            <MudMenuItem Disabled="@(!(context.Item.IStatus == IStatus.Draft))" OnClick="@(()=>OnEdit(context.Item))">@AppStrings.Edit</MudMenuItem>
                        }
                        }
                        @if (_accessRights.Delete)
                        {
                            <MudMenuItem OnClick="@(()=>OnDelete(context.Item))">@AppStrings.Delete</MudMenuItem>
                        }
                    </MudMenu>
                }
                else
                {
                    <MudIconButton Variant="Variant.Filled"
                    Disabled="true"
                    Icon="@Icons.Material.Filled.DoNotTouch"
                    Size="Size.Small"
                    Color="Color.Surface">
                        @AppStrings.NoAllowed
                    </MudIconButton>
                }
            </CellTemplate>
        </TemplateColumn>
        <PropertyColumn Property="x => x.InvNo" Title="@L[_currentDto.GetMemberDescription(x=>x.InvNo)]" />
        <PropertyColumn Property="x => x.IStatus" Title="@L[_currentDto.GetMemberDescription(x=>x.IStatus)]" />
        <PropertyColumn Property="x => x.InvDate" Title="@L[_currentDto.GetMemberDescription(x=>x.InvDate)]" />
        <PropertyColumn Property="x => x.DueDate" Title="@L[_currentDto.GetMemberDescription(x=>x.DueDate)]" />
       @*  <PropertyColumn Property="x => x.CustomerId" Title="@L[_currentDto.GetMemberDescription(x=>x.CustomerId)]" /> *@
        <PropertyColumn Property="x => x.Customer" Title="@L[_currentDto.GetMemberDescription(x => x.Customer)]" />
        <PropertyColumn Property="x => x.InvDesc" Title="@L[_currentDto.GetMemberDescription(x=>x.InvDesc)]" />
        <PropertyColumn Property="x => x.Total" Title="@L[_currentDto.GetMemberDescription(x=>x.Total)]" />
        <PropertyColumn Property="x => x.Taxes" Title="@L[_currentDto.GetMemberDescription(x=>x.Taxes)]" />
        <PropertyColumn Property="x => x.GrangTotal" Title="@L[_currentDto.GetMemberDescription(x=>x.GrangTotal)]" />
    </Columns>
    <NoRecordsContent>
        <MudText>@AppStrings.NoRecords</MudText>
    </NoRecordsContent>
    <LoadingContent>
        <MudText>@AppStrings.Loading</MudText>
    </LoadingContent>
    <PagerContent>
        <MudDataGridPager PageSizeOptions="@(new int[]{10,15,30,50,100})" />
    </PagerContent>
</MudDataGrid>



@code {
    [CascadingParameter] private UserProfile? UserProfile { get; set; }
    public string? Title { get; private set; }
    private HashSet<InvoiceDto> _selectedItems = new();
    private MudDataGrid<InvoiceDto> _table = default!;
    private InvoiceDto _currentDto = new();
    private InvoicesAccessRights _accessRights = new();
    private int _defaultPageSize = 15;
    private bool _loading;
    private bool _exporting;
    private bool _downloading;


    private InvoicesWithPaginationQuery Query { get; set; } = new();




    private void ConditionChanged(string s)
    {
        InvokeAsync(_table.ReloadServerData);
    }

    protected override async Task OnInitializedAsync()
    {
        Title = L[_currentDto.GetClassDescription()];
        _accessRights = await PermissionService.GetAccessRightsAsync<InvoicesAccessRights>();

    }
    private async Task<GridData<InvoiceDto>> ServerReload(GridState<InvoiceDto> state)
    {
        try
        {
            _loading = true;
            Query.CurrentUser = UserProfile;
            Query.OrderBy = state.SortDefinitions.FirstOrDefault()?.SortBy ?? "Id";
            Query.SortDirection = state.SortDefinitions.FirstOrDefault()?.Descending ?? true
                                              ? SortDirection.Descending.ToString()
                                              : SortDirection.Ascending.ToString();
            Query.PageNumber = state.Page + 1;
            Query.PageSize = state.PageSize;
            var result = await Mediator.Send(Query).ConfigureAwait(false);
            return new GridData<InvoiceDto> { TotalItems = result.TotalItems, Items = result.Items };

        }
        finally
        {
            _loading = false;
        }

    }
    private async Task OnSearch(string text)
    {
        _selectedItems = new HashSet<InvoiceDto>();
        Query.Keyword = text;
        await _table.ReloadServerData();
    }
    private async Task OnChangedListView(InvoiceListView listview)
    {
        Query.ListView = listview;
        await _table.ReloadServerData();
    }
    private async Task OnRefresh()
    {
        InvoiceCacheKey.Refresh();
        _selectedItems = new HashSet<InvoiceDto>();
        Query.Keyword = string.Empty;
        await _table.ReloadServerData();
    }

    private Task OnView(InvoiceDto dto)
    {
        Navigation.NavigateTo($"/pages/TrdBx/Invoices/{dto.Id}/view");
        return Task.CompletedTask;
    }

    private Task OnCreate()
    {
        var command = new CreateInvoiceCommand() {};
        return DialogServiceHelper.ShowFormDialogAsync<InvoiceCreateFormDialog, CreateInvoiceCommand>(
            L["Create Invoice"],
           new DialogParameters<InvoiceCreateFormDialog>
           {
                            { x=>x._model,command}
           },
           async () =>
           {
               await _table.ReloadServerData();
               _selectedItems.Clear();
           });
    }

    private Task OnEdit(InvoiceDto dto)
    {
        var command = Mapper.Map<UpdateInvoiceCommand>(dto);
        return DialogServiceHelper.ShowFormDialogAsync<InvoiceEditFormDialog, UpdateInvoiceCommand>(
           L["Update Invoice"],
           new DialogParameters<InvoiceEditFormDialog>
           {
                            { x=>x._model,command}
           },
           async () =>
           {
               await _table.ReloadServerData();
               _selectedItems.Clear();
           });
    }


    private Task OnSetNextStatus(InvoiceDto dto)
    {
        var contentText = string.Format(AppStrings.ExecuteConfirmation, " Set Next Status for Invoice ", dto.InvNo);
        var command = new SetAsCanceledInvoiceCommand(dto.Id);
        return DialogServiceHelper.ShowExecuteConfirmationDialogAsync(command, AppStrings.ExecuteConfirmationTitle, contentText, async () =>
        {
            await InvokeAsync(async () =>
            {
                await _table.ReloadServerData();
                _selectedItems.Clear();
            });
        });
    }

    private Task OnSetPreviousStatus(InvoiceDto dto)
    {
        var contentText = string.Format(AppStrings.ExecuteConfirmation, " Set Previous Status for Invoice ", dto.InvNo);
        var command = new SetAsCanceledInvoiceCommand(dto.Id);
        return DialogServiceHelper.ShowExecuteConfirmationDialogAsync(command, AppStrings.ExecuteConfirmationTitle, contentText, async () =>
        {
            await InvokeAsync(async () =>
            {
                await _table.ReloadServerData();
                _selectedItems.Clear();
            });
        });
    }

    private Task OnSetAsPaid(InvoiceDto dto)
    {
        var contentText = string.Format(AppStrings.ExecuteConfirmation, " Set Invoice " + dto.InvNo, "as Paid");
        var command = new SetAsCanceledInvoiceCommand(dto.Id);
        return DialogServiceHelper.ShowExecuteConfirmationDialogAsync(command, AppStrings.ExecuteConfirmationTitle, contentText, async () =>
        {
            await InvokeAsync(async () =>
            {
                await _table.ReloadServerData();
                _selectedItems.Clear();
            });
        });
    }

    private Task OnSetAsCanceled(InvoiceDto dto)
    {


        var contentText = string.Format(AppStrings.ExecuteConfirmation," Cancel Invoice", dto.InvNo);
        var command = new SetAsCanceledInvoiceCommand(dto.Id);

        return DialogServiceHelper.ShowExecuteConfirmationDialogAsync(command, AppStrings.ExecuteConfirmationTitle, contentText, async () =>
        {
            await InvokeAsync(async () =>
            {
                await _table.ReloadServerData();
                _selectedItems.Clear();
            });
        });
    }



    private Task OnDelete(InvoiceDto dto)
    {
        var contentText = string.Format(AppStrings.DeleteConfirmation, dto.InvNo);
        var command = new DeleteInvoiceCommand(dto.Id);
        return DialogServiceHelper.ShowDeleteConfirmationDialogAsync(
            command,
            AppStrings.DeleteConfirmationTitle,
            contentText,
            async () =>
            {
                await _table.ReloadServerData();
                _selectedItems.Clear();
            });
    }


    private async Task OnExport()
    {
        _exporting = true;
        var request = new ExportInvoicesQuery()
            {

                 Keyword = Query.Keyword,
                ListView = Query.ListView,
                CustomerId = Query.CustomerId,
                InvoiceType = Query.InvoiceType,
                IStatus = Query.IStatus,
                OrderBy = _table.SortDefinitions.Values.FirstOrDefault()?.SortBy ?? "InvNo",
                SortDirection = _table.SortDefinitions.Values.FirstOrDefault()?.Descending ?? false
                                            ? SortDirection.Descending.ToString()
                                            : SortDirection.Ascending.ToString(),
                CurrentUser = UserProfile,


            };

        var result = await Mediator.Send(request);
        await result.MatchAsync(
            async data =>
            {
                if (result.Data != null)
                {
                    await BlazorDownloadFileService.DownloadFileAsync($"{L[_currentDto.GetClassDescription()]}.xlsx", result.Data, contentType: "application/octet-stream");
                    Snackbar.Add($"{AppStrings.ExportSuccess}", MudBlazor.Severity.Info);
                }
                else
                {
                    Snackbar.Add($"{AppStrings.ExecuteFail}", MudBlazor.Severity.Error);
                }
            },
            errors =>
            {
                Snackbar.Add($"{errors}", MudBlazor.Severity.Error);
                return Task.CompletedTask;
            });
        _exporting = false;


    }


    private async Task OnDownLoad(InvoiceDto dto)
    {
        _downloading = true;

        var query = new DownloadInvoiceByIdQuery(dto.Id);

        var result = await Mediator.Send(query);

        if (result.Succeeded)
        {
            await BlazorDownloadFileService.DownloadFileAsync($"{dto.InvNo}.pdf", result.Data, "application/octet-stream");
            Snackbar.Add($"{AppStrings.ExportSuccess}", Severity.Info);
        }
        else
        {
            Snackbar.Add($"{result.ErrorMessage}", Severity.Error);
        }

        _downloading = false;
    }


}
